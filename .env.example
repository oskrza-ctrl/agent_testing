OPENAI_API_KEY=Aqui_va_tu_clave_de_API_de_OpenAI

# Telegram Bot (paso 20)
TELEGRAM_BOT_TOKEN=token_de_botfather

# Google Tasks (opcional)
GOOGLE_CREDENTIALS_FILE=credentials/credentials.json
GOOGLE_TOKEN_FILE=credentials/token.json

# Google Calendar (opcional — usa las mismas credenciales, token separado)
GOOGLE_CALENDAR_TOKEN_FILE=credentials/token_calendar.json
GOOGLE_CALENDAR_TIMEZONE=America/Mexico_City

# Google Drive (opcional — los 3 IDs son requeridos para activar Drive)
GOOGLE_DRIVE_TOKEN_FILE=credentials/token_drive.json
GOOGLE_DRIVE_INBOX_FOLDER_ID=ID_de_tu_carpeta_Inbox
GOOGLE_DRIVE_PROCESSED_FOLDER_ID=ID_de_tu_carpeta_Processed
GOOGLE_DRIVE_KB_FOLDER_ID=ID_de_tu_carpeta_Knowledge_Base

# LangSmith (opcional — tracing y observabilidad del pipeline)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=tu_api_key_de_langsmith
LANGCHAIN_PROJECT=Sencond-brain-agent